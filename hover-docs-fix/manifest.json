{
  "manifest_version": 3,
  "name": "DeX Hover & Docs Fix",
  "version": "1.0",
  "description": "DeX hover enforcer and Docs text selection fix.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://docs.google.com/*"],
      "js": ["docs_fix_injector.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["docs_fix.js"],
      "matches": ["*://docs.google.com/*"]
    }
  ]
}
